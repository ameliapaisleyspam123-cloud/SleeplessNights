{
  "name": "LoreEntry",
  "type": "object",
  "properties": {
    "campaign_id": {
      "type": "string",
      "description": "Campaign this entry belongs to"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "map",
        "character",
        "place",
        "event",
        "artifact",
        "religion",
        "other"
      ],
      "default": "other"
    },
    "folder": {
      "type": "string",
      "description": "Optional folder name to group entries"
    },
    "content": {
      "type": "string",
      "description": "Lore text / description"
    },
    "image_url": {
      "type": "string",
      "description": "Optional image or map URL"
    },
    "pdf_url": {
      "type": "string",
      "description": "Optional PDF attachment URL"
    },
    "pdf_rotation": {
      "type": "number",
      "default": 0,
      "description": "Clockwise rotation for rendering map PDFs"
    },
    "map_pins": {
      "type": "array",
      "description": "Pins placed on an attached map PDF, stored as percentage coordinates",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "pin",
              "label"
            ]
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "size": {
            "type": "number"
          },
          "lore_entry_id": {
            "type": "string",
            "description": "Optional linked LoreEntry id"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "dm_only",
        "archived",
        "specific_players"
      ],
      "default": "public",
      "description": "public = all players; dm_only = GM only; archived = hidden; specific_players = allowed_emails only"
    },
    "allowed_emails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Emails of players who can see this entry when visibility=specific_players"
    }
  },
  "required": [
    "title"
  ]
}
