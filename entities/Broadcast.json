{
  "name": "Broadcast",
  "type": "object",
  "properties": {
    "campaign_id": {
      "type": "string",
      "description": "Campaign this broadcast belongs to"
    },
    "active": {
      "type": "boolean",
      "default": false
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "video_url": {
      "type": "string",
      "description": "Optional uploaded video file URL"
    },
    "lore_entry_id": {
      "type": "string",
      "description": "Optional: a LoreEntry id to broadcast"
    },
    "target_emails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "If set, only show to these player emails. Empty = show to all."
    },
    "archived": {
      "type": "boolean",
      "default": false
    }
  },
  "required": []
}
